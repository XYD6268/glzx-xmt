# 环境变量示例（复制为 .env 后按需修改）

# --- 安全密钥 ---
SECRET_KEY="!y5MV@U#57$#57$6v!JT*^S74X#!PbrQ"

# --- 数据库配置（两种方式，优先使用 DATABASE_URL） ---
# 方式A：完整连接串（优先级更高）
# 例如：mysql+pymysql://user:password@localhost:3306/glzx_xmt?charset=utf8mb4
DATABASE_URL=postgresql+asyncpg://XYD:Xyd00000@localhost:5432/

# 方式B：分段配置（当 DATABASE_URL 为空时生效，拼成 MySQL 连接串）
DB_USER=XYD
DB_PASSWORD=Xyd00000
DB_HOST=localhost
DB_PORT=3306
DB_NAME=glzx_xmt

# --- SQLAlchemy 设置 ---
# 是否跟踪对象修改（会有性能开销），默认 False
SQLALCHEMY_TRACK_MODIFICATIONS=0

# --- 路径配置 ---
UPLOAD_FOLDER=phpto/uploads
THUMB_FOLDER=photo/thumbs

# --- 运行时设置 ---
# 是否开启调试（1/true/yes/on 为真）
FLASK_DEBUG=1
# 监听地址与端口
FLASK_RUN_HOST=127.0.0.1
FLASK_RUN_PORT=5000
